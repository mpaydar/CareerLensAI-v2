{
  "manifest_version": 3,
  "name": "ResumeSnap",
  "version": "1.0.8",
  "description": "Highlight any job description and tailor your resume instantly.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "http://localhost:3000/*",
    "http://127.0.0.1:3000/*",
    "http://localhost:3001/*",
    "http://127.0.0.1:3001/*",
    "https://*.vercel.app/*",
    "https://www.linkedin.com/*",
    "https://linkedin.com/*"
  ],
  "optional_host_permissions": ["https://*/*"],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "extension-config.js",
        "easy-apply-detector.js",
        "content.js"
      ],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}
